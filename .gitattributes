# Normaliza line endings para colaboración multiplataforma
* text=auto eol=lf

# Dart/Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Android
*.java   text eol=lf
*.kt     text eol=lf
*.gradle text eol=lf
*.xml    text eol=lf
*.properties text eol=lf

# iOS
*.swift  text eol=lf
*.h      text eol=lf
*.m      text eol=lf
*.pbxproj text eol=lf

# Binarios — sin conversión
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary
*.apk    binary
*.aab    binary
